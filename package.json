{
  "name": "moyu-browser",
  "version": "1.0.0",
  "description": "A stealth browser for relaxing at work.",
  "author": "Moyu Master",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.moyu.browser",
    "productName": "MoyuBrowser",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js",
      "package.json"
    ]
  }
}